<Window x:Class="DataBase.DataBaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataBase"
        mc:Ignorable="d"
        Title="DataBaseWindow" MinHeight="400" MinWidth="400" Height="400" Width="Auto"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
   
        <DataGrid x:Name="booksGrid"
                  AutoGenerateColumns="False"
                  Grid.Column="0"
                  FontFamily="DIALux Report Font Regular" 
                  FontSize="14" 
                  Background="#FFFFF5F5"
                  BorderBrush="{x:Null}" 
                  Foreground="Black"
                  RowBackground="#FFFFF5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"  Binding="{Binding Id}"/>

                <DataGridTextColumn Header="Название книги" 
                            Width="*" 
                            Binding="{Binding Title, UpdateSourceTrigger=LostFocus}"/>

                <DataGridTextColumn Header="Автор" 
                            Width="*" 
                            Binding="{Binding Author, UpdateSourceTrigger=LostFocus}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" >
            <TextBlock Text=" Сортировать по" Width="100" Margin =" 5" HorizontalAlignment="Left"/>
            <RadioButton x:Name="IdSort" Content="Id" Margin ="5" IsChecked="True" Checked="Sort_Checked"/>
            <RadioButton x:Name="NameSort" Content="Названию книги" Margin ="5" Checked="Sort_Checked"/>
            <RadioButton x:Name="AuthorSort" Content="Автору" Margin ="5" Checked="Sort_Checked"/>
            <TextBlock Text="Название" Margin="5"/>
            <TextBox Name="title" Width="150" Margin="5"/>
            <TextBlock Text="Автор" Margin="5"/>
            <TextBox Name="author" Width="150" Margin="5"/>
            <Button Click="Add_Click" Content="Добавить" Width="100" Margin="5"/>
            <Button Click="Delete_Click" Content="Удалить" Width="100" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
